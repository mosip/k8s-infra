{
  "title": "Loki - Kubernetes Logs (RKE2)",
  "uid": "loki-rke2-logs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values(namespace)",
        "query": "label_values(namespace)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+"
      },
      {
        "name": "pod",
        "type": "query",
        "label": "Pod",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({namespace=~\"$namespace\"}, pod)",
        "query": "label_values({namespace=~\"$namespace\"}, pod)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+"
      },
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({namespace=~\"$namespace\", pod=~\"$pod\"}, container)",
        "query": "label_values({namespace=~\"$namespace\", pod=~\"$pod\"}, container)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+"
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search (case insensitive)",
        "current": { "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Log Lines",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum(count_over_time({namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))",
        "legendFormat": "Total Logs"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color": "green", "value": null}] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Count (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum(count_over_time({namespace=~\"$namespace\", pod=~\"$pod\"} |= \"error\" [5m]))",
        "legendFormat": "Errors"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Warn Count (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum(count_over_time({namespace=~\"$namespace\", pod=~\"$pod\"} |= \"warn\" [5m]))",
        "legendFormat": "Warnings"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Namespaces",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "count(count by (namespace) (count_over_time({namespace=~\".+\"}[5m])))",
        "legendFormat": "Namespaces"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color": "blue", "value": null}] } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log Rate by Namespace",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum by (namespace) (rate({namespace=~\"$namespace\", pod=~\"$pod\"}[2m]))",
        "legendFormat": "{{namespace}}"
      }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate by Namespace",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum by (namespace) (rate({namespace=~\"$namespace\", pod=~\"$pod\"} |= \"error\" [2m]))",
        "legendFormat": "{{namespace}} errors"
      }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Live Logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{namespace=~\"$namespace\", pod=~\"$pod\"} |~ \"(?i)$search\"",
        "legendFormat": ""
      }],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "__inputs": [
    {
      "name": "DS_LOKI",
      "type": "datasource",
      "pluginId": "loki",
      "label": "Loki"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ]
}
