{
  "title": "MOSIP Insight",
  "uid": "mosip-insight-loki",
  "description": "Equivalent of Kibana MOSIP Insight dashboard. Tracks registration processing pipeline: MinIO upload → Packet Validation → Quality Check → Bio/Demo Dedupe → UIN Generation. Each stage shows total count (stat) + throughput per hour (timeseries).",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
        "definition": "label_values(namespace)",
        "query": "label_values(namespace)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {"text": "regproc", "value": "regproc"}
      }
    ]
  },
  "panels": [

    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": {"h": 2, "w": 24, "x": 0, "y": 0},
      "options": {
        "mode": "markdown",
        "content": "## 📦 Stage 1 — Packet Upload to MinIO\n`regproc-group6` | `Packet is Uploaded to Packet Store`"
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Packets Uploaded to MinIO",
      "description": "Total count of packets successfully uploaded to MinIO (Packet Store) in the selected time range.",
      "gridPos": {"h": 6, "w": 5, "x": 0, "y": 2},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", app=~\"regproc-group6\"} |= \"Packet is Uploaded to Packet Store\" [$__range]))",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto", "orientation": "auto"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "blue", "value": null}]},
          "mappings": []
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Packets Uploaded to MinIO per hour",
      "description": "Count of packets uploaded to MinIO per hour. Equivalent of Kibana line chart with 1h date histogram.",
      "gridPos": {"h": 6, "w": 19, "x": 5, "y": 2},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", app=~\"regproc-group6\"} |= \"Packet is Uploaded to Packet Store\" [1h]))",
          "legendFormat": "Uploaded to MinIO",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "#5794F2", "mode": "fixed"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "spanNulls": true}
        }
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },

